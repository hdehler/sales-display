# Slack Configuration
# Create a Slack App at https://api.slack.com/apps
# Enable Socket Mode and get these tokens:
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Channel ID (C... public, G... private). NOT #channel-name.
# In Slack: open channel > title > View channel details > copy Channel ID at bottom.
SLACK_SALES_CHANNEL_ID=

# In api.slack.com > Event Subscriptions, subscribe to BOTH if Slide posts in:
#   message.channels (public)   message.groups (private)
# Set to 1 to log Block Kit messages that didn't parse
SLACK_DEBUG_PARSE=0
# Log every Socket message event (proves whether Slack delivers live events)
SLACK_LOG_MESSAGE_EVENTS=0
# Poll channel history (ms). Default 120000 (2 min). Backup: catches Slide when Socket delivers empty payloads. 0 = OFF
SLACK_POLL_HISTORY_MS=120000
# Log each poll tick
SLACK_LOG_POLL=0

# Import existing channel messages on startup (parsed orders only; no celebrations)
SLACK_BACKFILL_ON_START=false
SLACK_BACKFILL_MAX_MESSAGES=500
SLACK_BACKFILL_PAGE_DELAY_MS=1200

# Slide: quiet period (ms) after the last order before one batched celebration (default 1500)
SLIDE_BATCH_DEBOUNCE_MS=1500
# Full-screen celebration for every Slide order (default on). Set false to only celebrate on keywords/milestone
CELEBRATE_SLIDE_ORDERS=true

# Kasa Smart Plug Configuration (Path A — direct LAN control from this server)
# Plugs must be on the same LAN/subnet as the Pi (guest Wi‑Fi / isolated IoT VLANs often block this).
# Comma-separated IPs (optional if auto-discovery finds your plugs).
KASA_PLUG_HOSTS=
# Set to "false" to disable UDP discovery and use only KASA_PLUG_HOSTS (recommended if IPs are fixed).
KASA_AUTO_DISCOVER=true
# If legacy port 9999 fails, the server uses python-kasa. On Pi OS use a venv: `make install-kasa`, then:
# KASA_PYTHON_BIN=/home/pi/sales-display/.venv-kasa/bin/python

# Home Assistant (optional Path B — webhook when celebrations start/end)
# In HA: Settings → Automations → Create → Triggers → Webhook. Paste the full webhook URL here.
# JSON body: {"phase":"start"|"end","durationSeconds":N,"source":"sales-display"}
# HOME_ASSISTANT_CELEBRATION_WEBHOOK_URL=
# When true, skip local Kasa API calls (HA automations control the plugs).
# HOME_ASSISTANT_PLUGS_ONLY=false

# Celebration Configuration
# How long celebrations last in seconds (matches plug ON time and full-screen celebration length)
CELEBRATION_DURATION=30
# Comma-separated product keywords that trigger celebrations (when CELEBRATE_SLIDE_ORDERS is false)
CELEBRATION_TRIGGER_PRODUCTS=enterprise,premium
# Trigger a milestone celebration every N sales per day (0 to disable)
MILESTONE_INTERVAL=10

# Server
PORT=3000

# ── BigQuery: Slide account → sales rep (optional) ──────────────────────────
# Service account JSON path (recommended on Pi). Needs BigQuery Job User + dataViewer.
# GOOGLE_APPLICATION_CREDENTIALS=/home/pi/keys/bq-sa.json
#
BIGQUERY_PROJECT_ID=dwh-prod-484216
# project.dataset.table — no backticks
BIGQUERY_ACCOUNT_OWNER_TABLE=dwh-prod-484216.marts.rpt_console_account_hubspot_owner
BIGQUERY_ACCOUNT_NAME_COLUMN=account_name
BIGQUERY_OWNER_NAME_COLUMN=hubspot_owner_resolved_name
BIGQUERY_ACCOUNT_OWNER_ORDER_BY=account_id
# BigQuery job location if required (US, EU, …)
BIGQUERY_LOCATION=
BIGQUERY_LOOKUP_CACHE_MAX=512

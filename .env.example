# Slack Configuration
# Create a Slack App at https://api.slack.com/apps
# Enable Socket Mode and get these tokens:
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Channel ID (C... public, G... private). NOT #channel-name.
# In Slack: open channel > title > View channel details > copy Channel ID at bottom.
SLACK_SALES_CHANNEL_ID=
# Optional: channel where HubSpot posts demo bookings (BDR = credited rep). Invite the bot here too.
# When set, this channel is never treated as the sales channel.
# Backfill April etc.: npm run demo-bookings-backfill -- 2026-04-01 2026-04-30 (needs this ID + BACKFILL_TIMEZONE if not UTC)
SLACK_DEMO_BOOKINGS_CHANNEL_ID=

# In api.slack.com > Event Subscriptions, subscribe to BOTH if Slide posts in:
#   message.channels (public)   message.groups (private)
# Set to 1 to log Block Kit messages that didn't parse
SLACK_DEBUG_PARSE=0
# Log every Socket message event (proves whether Slack delivers live events)
SLACK_LOG_MESSAGE_EVENTS=0
# Poll channel history (ms). Default 120000 (2 min). Backup: catches Slide when Socket delivers empty payloads. 0 = OFF
SLACK_POLL_HISTORY_MS=120000
# Log each poll tick
SLACK_LOG_POLL=0

# Import existing channel messages on startup (parsed orders only; no celebrations)
SLACK_BACKFILL_ON_START=false
SLACK_BACKFILL_MAX_MESSAGES=500
SLACK_BACKFILL_PAGE_DELAY_MS=1200
# `npm run slack-backfill` with two dates: those days are interpreted in this IANA timezone (calendar midnights). Leave unset for UTC.
# BACKFILL_TIMEZONE=America/New_York

# Slide: quiet period (ms) after the last order before one batched celebration (default 1500)
SLIDE_BATCH_DEBOUNCE_MS=1500
# Full-screen celebration for every Slide order (default on). Set false to only celebrate on keywords/milestone.
# HubSpot demo bookings use the same flag (not order milestones).
CELEBRATE_SLIDE_ORDERS=true

# Celebration Configuration
# How long celebrations last in seconds
CELEBRATION_DURATION=30
# Optional (Raspberry Pi): turn a USB disco / party light on for the celebration, off when it ends.
# Set BOTH. Discover hub location on THIS Pi — do not copy examples blindly:
#   sudo apt install uhubctl && sudo uhubctl
# Only `-l` / `-p` values that appear in that listing will work. Pi 4 often uses `-l 2` or `-l 1-1`
# with `-p 4`.
# Pi 5: all four Type-A ports share one VBUS — per README, often need BOTH hubs (cuts power to ALL USB-A):
#   CELEBRATION_USB_OFF_CMD=sh -c 'sudo uhubctl -l 2 -a 0; sudo uhubctl -l 4 -a 0'
#   CELEBRATION_USB_ON_CMD=sh -c 'sudo uhubctl -l 2 -a 1; sudo uhubctl -l 4 -a 1'
# A single `-l 3 -p 1` can print "off" while the lamp stays on — wrong location → "No compatible devices detected".
# CELEBRATION_USB_ON_CMD=sudo uhubctl -l 2 -p 4 -a 1
# CELEBRATION_USB_OFF_CMD=sudo uhubctl -l 2 -p 4 -a 0
# Default: run OFF when the server starts (several times at staggered delays — Pi USB often ignores the first try).
# CELEBRATION_USB_OFF_ON_START=true
# Optional comma-separated delays in ms (default 0,2500,5000,10000,15000):
# CELEBRATION_USB_STARTUP_OFF_DELAYS_MS=0,2500,5000,10000,15000
# If one uhubctl line is not enough, put ALL needed lines in ONE var (Pi 5: see pair above).
# Comma-separated product keywords that trigger celebrations
CELEBRATION_TRIGGER_PRODUCTS=enterprise,premium
# Trigger a milestone celebration every N sales per day (0 to disable)
MILESTONE_INTERVAL=10

# Server
PORT=3000

# ── BigQuery: Slide account → sales rep (optional) ──────────────────────────
# Service account JSON path (recommended on Pi). Needs BigQuery Job User + dataViewer.
# GOOGLE_APPLICATION_CREDENTIALS=/home/pi/keys/bq-sa.json
#
BIGQUERY_PROJECT_ID=dwh-prod-484216
# project.dataset.table — no backticks
BIGQUERY_ACCOUNT_OWNER_TABLE=dwh-prod-484216.marts.rpt_console_account_hubspot_owner
# BigQuery job location if required (US, EU, us-east4, …)
BIGQUERY_LOCATION=
BIGQUERY_LOOKUP_CACHE_MAX=512
#
# Column names — optional overrides. Defaults match rpt_console_account_hubspot_owner-style marts:
#   account column   = account_name
#   hunter (AE) col  = account_executive_name   (first order ever → credit AE)
#   farmer (AM) col  = account_manager_name      (later orders → credit AM)
#   legacy fallback  = hubspot_company_owner_name (when AE/AM empty; set "" to disable)
#   tie-break order  = account_id
# Older marts with account_executive / account_manager / hubspot_owner_resolved_name:
# BIGQUERY_HUNTER_COLUMN=account_executive
# BIGQUERY_FARMER_COLUMN=account_manager
# BIGQUERY_OWNER_NAME_COLUMN=hubspot_owner_resolved_name
# Re-run DWH lookup for Slide rows still stored as Unknown (late HubSpot owner). 0 = off. 900000 = 15 min.
BIGQUERY_RECONCILE_UNKNOWN_MS=0
